    classDef layer fill:#ffffff,stroke:#cbd5e1,stroke-width:1px,color:#0f172a;
    classDef access fill:#eef6ff,stroke:#60a5fa,stroke-width:1.5px,color:#0f172a;
    classDef presentation fill:#eff6ff,stroke:#2563eb,stroke-width:1.5px,color:#0f172a;
    classDef application fill:#f0fdf4,stroke:#16a34a,stroke-width:1.5px,color:#0f172a;
    classDef domain fill:#f8fafc,stroke:#64748b,stroke-width:1.5px,color:#0f172a;
    classDef infra fill:#fff7ed,stroke:#ea580c,stroke-width:1.5px,color:#0f172a;
