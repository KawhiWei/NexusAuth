{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Frontend": {
    "BaseUrl": "http://localhost:5200"
  },
  "NexusAuth": {
    "Authority": "http://localhost:5100",
    "ClientId": "demo-bff",
    "ClientSecret": "demo-bff-secret",
    "RedirectUri": "http://localhost:5201/signin-oidc",
    "PostLogoutRedirectUri": "http://localhost:5200/",
    "Scope": "openid profile email phone offline_access demo_api"
  },
  "MobileAuth": {
    "ClientId": "demo-mobile",
    "ClientSecret": "demo-mobile-secret",
    "RedirectUri": "myapp://auth/callback",
    "Scope": "openid profile email phone offline_access demo_api"
  },
  "Jwt": {
    "Issuer": "http://localhost:5100",
    "Audience": "NexusAuth",
    "WebAudience": "demo-bff-api",
    "MobileAudience": "demo-mobile-api"
  }
}
